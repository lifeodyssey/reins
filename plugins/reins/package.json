{
  "name": "claude-plugin-reins",
  "version": "0.6.0",
  "description": "Multi-agent sprint orchestrator for Claude Code",
  "keywords": [
    "claude-code-plugin",
    "harness",
    "orchestrator",
    "multi-agent",
    "sprint"
  ],
  "license": "MIT",
  "files": [
    ".claude-plugin/",
    "commands/",
    "agents/",
    "skills/",
    "hooks/",
    "src/"
  ],
  "scripts": {
    "dev": "bun run src/server.ts",
    "build": "bun build --compile src/server.ts --outfile reins",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.114"
  },
  "devDependencies": {
    "bun-types": "^1.3.12",
    "typescript": "^6.0.3"
  }
}
